generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Employee {
  id                 Int      @id @default(autoincrement())

  registrationNumber String   @unique
  name               String
  email              String?
  cpf                String   @unique
  phone              String?
  messageReads ReportMessageRead[]
  department         String?

  reports            Report[]
  messages           ReportMessage[]
  participations     ReportParticipant[]

  user               User?

  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt
  deletedAt          DateTime?

  @@index([registrationNumber])
  @@index([cpf])
}

model User {
  id           Int      @id @default(autoincrement())

  employeeId   Int?     @unique
  email        String   @unique
  passwordHash String
  role         UserRole

  employee     Employee? @relation(fields: [employeeId], references: [id])

  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  deletedAt    DateTime?

  @@index([email])
}

model Category {
  id          Int      @id @default(autoincrement())

  name        String   @unique
  icon        String?

  reports     Report[]

  createdAt   DateTime @default(now())

  @@index([name])
}

model ReportStatus {
  id          Int      @id @default(autoincrement())

  name        String   @unique
  color       String?

  reports     Report[]

  createdAt   DateTime @default(now())

  @@index([name])
}

model Report {
  id               Int      @id @default(autoincrement())

  employeeId       Int
  categoryId       Int
  statusId         Int

  title            String?
  description      String?
  referencePoint   String?

  latitude         Float?
  longitude        Float?
  address          String?

  employee         Employee     @relation(fields: [employeeId], references: [id])
  category         Category     @relation(fields: [categoryId], references: [id])
  status           ReportStatus @relation(fields: [statusId], references: [id])

  messageReads     ReportMessageRead[]

  images           ReportImage[]
  messages         ReportMessage[]
  participants     ReportParticipant[]

  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
  deletedAt        DateTime?

  @@index([employeeId])
  @@index([categoryId])
  @@index([statusId])
  @@index([createdAt])
}

model ReportImage {
  id           Int      @id @default(autoincrement())

  reportId     Int
  imageUrl     String
  publicId     String?
  resourceType String?  @default("image")

  report       Report @relation(fields: [reportId], references: [id])

  createdAt    DateTime @default(now())

  @@index([reportId])
  @@index([publicId])
}

model ReportMessage {
  id         Int      @id @default(autoincrement())

  reportId   Int
  senderId   Int?
  senderName String
  senderRole String
  media      ReportMessageMedia[]
  message    String

  report     Report    @relation(fields: [reportId], references: [id])
  sender     Employee? @relation(fields: [senderId], references: [id])

  replyToMessageId Int?

  replyToMessage ReportMessage? @relation("MessageReplies", fields: [replyToMessageId], references: [id])
  replies        ReportMessage[] @relation("MessageReplies")
  mediaUrl     String?
  publicId     String?
  resourceType String? @default("image")

  createdAt  DateTime @default(now())

  @@index([reportId])
  @@index([senderId])
}

model ReportMessageMedia {
  id           Int      @id @default(autoincrement())

  messageId    Int
  mediaUrl     String
  publicId     String?
  resourceType String?  @default("image")

  message      ReportMessage @relation(fields: [messageId], references: [id])

  createdAt    DateTime @default(now())

  @@index([messageId])
  @@index([publicId])
}

model ReportMessageRead {
  id              Int      @id @default(autoincrement())

  reportId        Int
  employeeId      Int
  lastReadMessageId Int?

  report          Report   @relation(fields: [reportId], references: [id])
  employee        Employee @relation(fields: [employeeId], references: [id])

  updatedAt       DateTime @updatedAt
  createdAt       DateTime @default(now())

  @@unique([reportId, employeeId])
  @@index([reportId])
  @@index([employeeId])
}

model ReportParticipant {
  id         Int      @id @default(autoincrement())

  reportId   Int
  employeeId Int
  role       String   @default("PARTICIPANT")

  report     Report   @relation(fields: [reportId], references: [id])
  employee   Employee @relation(fields: [employeeId], references: [id])

  createdAt  DateTime @default(now())

  @@unique([reportId, employeeId])
  @@index([reportId])
  @@index([employeeId])
}

enum UserRole {
  ADMIN
  EMPLOYEE
}