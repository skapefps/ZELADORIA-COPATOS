generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Employee {
  id                 Int      @id @default(autoincrement())

  registrationNumber String   @unique
  name               String
  email              String?
  cpf                String   @unique
  phone              String?
  messageReads ReportMessageRead[]
  department         String?
  activeSessionToken String?

  reports            Report[]
  notes              ReportNote[]
  messages           ReportMessage[]
  participations     ReportParticipant[]

  notificationsReceived Notification[] @relation("NotificationRecipient")
  notificationsTriggered Notification[] @relation("NotificationActor")

  messageMentions        ReportMessageMention[]

  privateConversationParticipants PrivateConversationParticipant[]
  privateMessages                 PrivateMessage[]
  privateMessageReads             PrivateMessageRead[]

  user               User?

  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt
  deletedAt          DateTime?

  @@index([registrationNumber])
  @@index([cpf])
}

model User {
  id           Int      @id @default(autoincrement())

  employeeId   Int?     @unique
  email        String   @unique
  passwordHash String
  role         UserRole

  employee     Employee? @relation(fields: [employeeId], references: [id])

  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  deletedAt    DateTime?

  @@index([email])
}

model Category {
  id          Int      @id @default(autoincrement())

  name        String   @unique
  icon        String?

  reports     Report[]

  createdAt   DateTime @default(now())

  @@index([name])
}

model ReportStatus {
  id          Int      @id @default(autoincrement())

  name        String   @unique
  color       String?

  reports     Report[]

  createdAt   DateTime @default(now())

  @@index([name])
}

model Report {
  id               Int      @id @default(autoincrement())

  employeeId       Int
  categoryId       Int
  statusId         Int

  title            String?
  description      String?
  referencePoint   String?

  latitude         Float?
  longitude        Float?
  address          String?

  employee         Employee     @relation(fields: [employeeId], references: [id])
  category         Category     @relation(fields: [categoryId], references: [id])
  status           ReportStatus @relation(fields: [statusId], references: [id])

  messageReads     ReportMessageRead[]

  images           ReportImage[]
  messages         ReportMessage[]
  participants     ReportParticipant[]
  notifications    Notification[]
  notes            ReportNote[]

  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
  deletedAt        DateTime?

  @@index([employeeId])
  @@index([categoryId])
  @@index([statusId])
  @@index([createdAt])
}

model ReportNote {
  id         Int      @id @default(autoincrement())

  reportId  Int
  authorId  Int
  content   String

  report    Report   @relation(fields: [reportId], references: [id])
  author    Employee @relation(fields: [authorId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([reportId])
  @@index([authorId])
  @@index([createdAt])
}

model ReportImage {
  id           Int      @id @default(autoincrement())

  reportId     Int
  imageUrl     String
  publicId     String?
  resourceType String?  @default("image")

  report       Report @relation(fields: [reportId], references: [id])

  createdAt    DateTime @default(now())

  @@index([reportId])
  @@index([publicId])
}

model ReportMessage {
  id         Int      @id @default(autoincrement())

  reportId   Int
  senderId   Int?
  senderName String
  senderRole String
  media      ReportMessageMedia[]
  mentions   ReportMessageMention[]
  notifications Notification[]
  message    String

  report     Report    @relation(fields: [reportId], references: [id])
  sender     Employee? @relation(fields: [senderId], references: [id])

  replyToMessageId Int?

  replyToMessage ReportMessage? @relation("MessageReplies", fields: [replyToMessageId], references: [id])
  replies        ReportMessage[] @relation("MessageReplies")
  mediaUrl     String?
  publicId     String?
  resourceType String? @default("image")

  createdAt  DateTime @default(now())

  @@index([reportId])
  @@index([senderId])
}

model ReportMessageMedia {
  id           Int      @id @default(autoincrement())

  messageId    Int
  mediaUrl     String
  publicId     String?
  resourceType String?  @default("image")

  message      ReportMessage @relation(fields: [messageId], references: [id])

  createdAt    DateTime @default(now())

  @@index([messageId])
  @@index([publicId])
}

model ReportMessageRead {
  id              Int      @id @default(autoincrement())

  reportId        Int
  employeeId      Int
  lastReadMessageId Int?

  report          Report   @relation(fields: [reportId], references: [id])
  employee        Employee @relation(fields: [employeeId], references: [id])

  updatedAt       DateTime @updatedAt
  createdAt       DateTime @default(now())

  @@unique([reportId, employeeId])
  @@index([reportId])
  @@index([employeeId])
}

model ReportParticipant {
  id         Int      @id @default(autoincrement())

  reportId   Int
  employeeId Int
  role       String   @default("PARTICIPANT")

  report     Report   @relation(fields: [reportId], references: [id])
  employee   Employee @relation(fields: [employeeId], references: [id])

  createdAt  DateTime @default(now())

  @@unique([reportId, employeeId])
  @@index([reportId])
  @@index([employeeId])
}

model ReportMessageMention {
  id         Int      @id @default(autoincrement())

  messageId  Int
  employeeId Int

  message    ReportMessage @relation(fields: [messageId], references: [id])
  employee   Employee      @relation(fields: [employeeId], references: [id])

  createdAt  DateTime @default(now())

  @@unique([messageId, employeeId])
  @@index([messageId])
  @@index([employeeId])
}

model Notification {
  id          Int      @id @default(autoincrement())

  recipientId Int
  actorId     Int?

  type        String
  title       String
  body        String?

  reportId    Int?
  messageId   Int?
  privateConversationId Int?
  privateMessageId      Int?

  readAt      DateTime?
  createdAt   DateTime @default(now())

  recipient   Employee @relation("NotificationRecipient", fields: [recipientId], references: [id])
  actor       Employee? @relation("NotificationActor", fields: [actorId], references: [id])

  report      Report? @relation(fields: [reportId], references: [id])
  message     ReportMessage? @relation(fields: [messageId], references: [id])

  privateConversation PrivateConversation? @relation(fields: [privateConversationId], references: [id])
  privateMessage      PrivateMessage? @relation(fields: [privateMessageId], references: [id])

  @@index([recipientId])
  @@index([actorId])
  @@index([reportId])
  @@index([messageId])
  @@index([privateConversationId])
  @@index([privateMessageId])
  @@index([readAt])
  @@index([createdAt])
}

model PrivateConversation {
  id           Int      @id @default(autoincrement())

  participants PrivateConversationParticipant[]
  messages     PrivateMessage[]
  notifications Notification[]

  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@index([updatedAt])
}

model PrivateConversationParticipant {
  id             Int      @id @default(autoincrement())

  conversationId Int
  employeeId     Int

  conversation   PrivateConversation @relation(fields: [conversationId], references: [id])
  employee       Employee            @relation(fields: [employeeId], references: [id])

  createdAt      DateTime @default(now())

  @@unique([conversationId, employeeId])
  @@index([conversationId])
  @@index([employeeId])
}

model PrivateMessage {
  id             Int      @id @default(autoincrement())

  conversationId Int
  senderId       Int

  message        String
  mediaUrl       String?
  publicId       String?
  resourceType   String? @default("text")
  media          PrivateMessageMedia[]

  conversation   PrivateConversation @relation(fields: [conversationId], references: [id])
  sender         Employee            @relation(fields: [senderId], references: [id])

  reads          PrivateMessageRead[]
  notifications  Notification[]

  replyToMessageId Int?
  replyToMessage   PrivateMessage?  @relation("PrivateMessageReplies", fields: [replyToMessageId], references: [id])
  replies          PrivateMessage[] @relation("PrivateMessageReplies")

  createdAt      DateTime @default(now())

  @@index([conversationId])
  @@index([senderId])
  @@index([createdAt])
}

model PrivateMessageRead {
  id              Int      @id @default(autoincrement())

  conversationId  Int
  employeeId      Int
  lastReadMessageId Int?

  employee        Employee @relation(fields: [employeeId], references: [id])
  lastReadMessage PrivateMessage? @relation(fields: [lastReadMessageId], references: [id])

  updatedAt       DateTime @updatedAt
  createdAt       DateTime @default(now())

  @@unique([conversationId, employeeId])
  @@index([conversationId])
  @@index([employeeId])
}

model PrivateMessageMedia {
  id           Int      @id @default(autoincrement())

  messageId    Int
  mediaUrl     String
  publicId     String?
  resourceType String?  @default("image")

  message      PrivateMessage @relation(fields: [messageId], references: [id])

  createdAt    DateTime @default(now())

  @@index([messageId])
}

enum UserRole {
  ADMIN
  EMPLOYEE
}
